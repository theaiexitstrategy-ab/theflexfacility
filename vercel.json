{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "book.theflexfacility.com" }],
      "destination": "/flex-booking-calendar.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "book.theflexfacility.com" }],
      "destination": "/flex-booking-calendar.html"
    },
    { "source": "/fit", "destination": "/index7.html" },
    { "source": "/thank-you", "destination": "/thank-you.html" },
    { "source": "/ebook", "destination": "/ebook-order-page.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}